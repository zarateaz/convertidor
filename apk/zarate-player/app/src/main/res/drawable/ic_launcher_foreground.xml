<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Neon Amber / Copper Glow (Glass Bowl and Headset) -->
    <!-- Headset Band -->
    <path
        android:fillColor="#00000000"
        android:pathData="M26,52 C26,22 82,22 82,52"
        android:strokeWidth="4"
        android:strokeColor="#FFBF00"
        android:strokeLineCap="round" />

    <!-- Headset Cushion Detail -->
    <path
        android:fillColor="#00000000"
        android:pathData="M34,44 C34,28 74,28 74,44"
        android:strokeWidth="1.5"
        android:strokeColor="#BF00FF"
        android:strokeLineCap="round" />

    <!-- Left Ear Cup -->
    <path
        android:fillColor="#B87333"
        android:pathData="M18,46 C18,42 24,42 24,46 L24,62 C24,66 18,66 18,62 Z" />
    <path
        android:fillColor="#BF00FF"
        android:pathData="M24,48 L26,48 L26,60 L24,60 Z" />

    <!-- Right Ear Cup -->
    <path
        android:fillColor="#B87333"
        android:pathData="M84,46 C84,42 90,42 90,46 L90,62 C90,66 84,66 84,62 Z" />
    <path
        android:fillColor="#BF00FF"
        android:pathData="M82,48 L84,48 L84,60 L82,60 Z" />

    <!-- Wine Glass Base & Stem (Copper/Bronze) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M44,82 L64,82"
        android:strokeWidth="3.5"
        android:strokeColor="#B87333"
        android:strokeLineCap="round" />
    <path
        android:fillColor="#00000000"
        android:pathData="M54,82 L54,64"
        android:strokeWidth="3.5"
        android:strokeColor="#B87333" />

    <!-- Wine Glass Cup Container -->
    <path
        android:fillColor="#1A0D0D0D"
        android:pathData="M38,42 C38,64 70,64 70,42 Z"
        android:strokeWidth="2.5"
        android:strokeColor="#FFBF00" />

    <!-- Glowing Cyber Wine Liquid (Rose/Amber Violet Gradient) -->
    <path
        android:pathData="M40,50 C40,62 68,62 68,50 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="62"
                android:startX="54"
                android:startY="50"
                android:type="linear">
                <item
                    android:color="#FFBF00"
                    android:offset="0.0" />
                <item
                    android:color="#BF00FF"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Play/Pause Core Icon Over Wine Cup -->
    <path
        android:fillColor="#000D0D"
        android:pathData="M50,46 L61,52 L50,58 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M51,48 L59,52 L51,56 Z" />
</vector>
